{
  "name": "loom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "node scripts/dev.mjs",
    "dev:api": "pnpm --filter @loom/server dev",
    "start": "pnpm --filter @loom/server start",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter @loom/web build",
    "format": "prettier --write 'packages/**/*.{ts,tsx,css,json}' '*.{json,md}' --ignore-path .gitignore",
    "format:check": "prettier --check 'packages/**/*.{ts,tsx,css,json}' '*.{json,md}' --ignore-path .gitignore",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,css,json,md}": "prettier --check --ignore-path .gitignore"
  },
  "devDependencies": {
    "concurrently": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^5.9.0",
    "vitest": "^2.1.0"
  }
}
