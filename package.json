{
  "name": "loom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev.mjs",
    "dev:api": "bun --cwd packages/server dev",
    "start": "bun --cwd packages/server start",
    "test": "vitest run",
    "test:watch": "bun vitest",
    "format": "bun --bun prettier --write . --ignore-unknown --ignore-path .gitignore --log-level warn",
    "format:check": "bun --bun prettier --check . --ignore-unknown --ignore-path .gitignore",
    "prepare": "bun --bun husky"
  },
  "workspaces": [
    "packages/*"
  ],
  "trustedDependencies": [
    "esbuild"
  ],
  "lint-staged": {
    "*.{ts,tsx,css,json,md}": "bun --bun prettier --check --ignore-path .gitignore"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^5.9.0",
    "vitest": "^2.1.0"
  }
}
