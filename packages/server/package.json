{
  "name": "@loom/server",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "bun run --cwd ../.. dev:api",
    "start": "bun src/index.ts",
    "test": "bun vitest run",
    "typecheck": "bun --bun tsc --noEmit -p tsconfig.json",
    "typecheck:test": "bun --bun tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@hono/zod-validator": "^0.8.0",
    "@loom/core": "workspace:*",
    "@modelcontextprotocol/sdk": "1.29.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.27",
    "js-yaml": "^4.1.0",
    "koffi": "3.1.1",
    "proper-lockfile": "^4.1.2",
    "simple-git": "^3.25.0",
    "tinyglobby": "^0.2.17",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "vitest": "^2.1.0"
  }
}
